# ============================================================
# .env.example — Sao chép thành .env và điền giá trị thực
# KHÔNG commit file .env lên GitLab!
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_root_password
DB_USERNAME=thermal_user
DB_PASSWORD=change_me_db_password
DB_URL=jdbc:mysql://thermal-power-plant-db.crysgaoaamwm.ap-northeast-1.rds.amazonaws.com:3306/m6_thermal_power_plant?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh

# ── JWT ──────────────────────────────────────────────────────
# Tạo secret mạnh: openssl rand -base64 64
JWT_SECRET=your_strong_base64_jwt_secret_here

# ── Mail ─────────────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here

# ── AWS (chỉ cần khi dùng docker-compose pull từ ECR) ────────
AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=197826770971
ECR_REGISTRY=197826770971.dkr.ecr.ap-northeast-1.amazonaws.com

# ── CloudFront (frontend deploy) ─────────────────────────────
S3_BUCKET=thermal-power-plant-frontend
CLOUDFRONT_DISTRIBUTION_ID=E1ABCDEF2GHIJK

# ── API URL (dùng khi build frontend) ────────────────────────
VITE_API_BASE_URL=https://api.your-domain.com
